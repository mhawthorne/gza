# Gza Configuration

# Project name (required) - used for branch prefixes and Docker image naming
project_name: my-project

# Project identity used to scope rows in shared task DB mode.
# gza init writes this automatically for new projects.
# In local DB mode (default), `project_id: default` is allowed.
# In shared mode (explicit db_path), project_id must be unique; if omitted,
# older configs derive a stable legacy ID from project path/name and warn.
# project_id: myproject01

# Optional local override file: gza.local.yaml (gitignored)
# Keep committed defaults here and put machine-specific settings in gza.local.yaml.

# Branch naming strategy (default: project_date_slug)
# Options: project_date_slug, monorepo, conventional, simple, date_slug,
# or a custom pattern dict. Variables: {project} {task_id} {task_slug}
# {date} {slug} {type}
# branch_strategy: project_date_slug  # Default: {project}/{date}-{slug}

# All settings below show default values and are commented out.
# Uncomment and modify any setting you want to change.

# --- Execution ---

# Whether to run Claude in Docker container
# use_docker: true

# Custom Docker image name (defaults to <project_name>-gza)
# docker_image: ""

# Additional Docker volume mounts
# docker_volumes: []

# Pre-warm hook: command run synchronously inside container before provider CLI starts
# Use for environment prep to avoid first-invocation install races (e.g., uv/poetry/pip/npm)
# docker_setup_command: ""

# Maximum time per task in minutes
# timeout_minutes: 10

# Optional fast verification command for code-task edit loops.
# verify_command remains the required final gate.
# inner_verify_command: ./bin/tests --quick

# Optional diff-size scaling for implement/improve/fix/rebase tasks.
# If the reviewable diff reaches the medium threshold, use at least the
# medium timeout. If it reaches the large threshold, use at least the large
# timeout. The final code-task budget cannot exceed
# code_task_diff_timeout_cap_minutes, even if a base override is higher.
# code_task_diff_timeout_medium_threshold: 400
# code_task_diff_timeout_large_threshold: 1200
# code_task_diff_timeout_medium_minutes: 30
# code_task_diff_timeout_large_minutes: 45
# code_task_diff_timeout_cap_minutes: 45

# Maximum execution steps per task
# max_steps: 50

# Number of tasks to run in a single work session (default: 1)
# work_count: 1

# Shell command run before finishing any task/implement/improve task.
# Autonomous review cycles also run this in the review worktree and turn failures/timeouts into review blockers.
# Agents are instructed to run this and fix any errors.
# Example: 'uv run mypy src/ && uv run pytest tests/ -x -q'
# verify_command: ""

# Timeout in seconds for autonomous review verify_command runs (default: 120)
# review_verify_timeout_seconds: 120

# Deprecated compatibility key. Accepted for older configs but ignored by current lifecycle planning.
# recommend_rebase_behind_commits: 1

# --- Branching ---

# Branch mode: "single" (reuse one branch) or "multi" (create branch per task)
# branch_mode: multi

# Directory for git worktrees (isolates task execution from main checkout)
# worktree_dir: /tmp/gza-worktrees

# --- Storage ---

# Task database path. Default is .gza/gza.db (project-local).
# gza init now asks whether to use a local or shared task DB.
# To opt into a shared DB after init, set db_path (for example ~/.gza/gza.db).
# Shared DB mode also requires an explicit project_id in gza.yaml.
# If ~/.gza/config.yaml already sets db_path, new projects can inherit it by
# leaving this line commented.
# If shared mode is active but a legacy local .gza/gza.db still exists, either:
#   uv run gza migrate --import-local-db --yes
# or keep the project local with:
# db_path: .gza/gza.db

# Directory for log files (relative to project directory)
# log_dir: .gza/logs

# --- Provider ---

# AI provider: "claude", "gemini", or "codex"
# provider: claude

# Route specific task types to a provider
# task_providers:
#   review: claude
#   implement: codex
#   fix: codex

# Provider-specific model name (optional)
# model: ""

# Codex reasoning effort override (optional: low, medium, high)
# reasoning_effort: ""

# Maximum characters of chat text to display (0 = unlimited)
# chat_text_display_length: 0

# --- Per-task-type overrides ---
# task_types:
#   plan:
#     model: claude-sonnet-4-20250514
#     reasoning_effort: medium
#     max_steps: 30
#   review:
#     model: claude-sonnet-4-20250514
#     reasoning_effort: low
#   fix:
#     model: claude-sonnet-4-20250514
#     reasoning_effort: high

# --- Learnings ---

# Number of recent completed tasks to include in learnings update prompt (default: 25)
# learnings_window: 25

# Auto-update learnings every N completed tasks; set to 0 to disable (default: 5)
# learnings_interval: 5

# --- Advance/Iterate ---

# Automatic failed-task recovery toggle:
#   0 disables resume/retry recovery; any positive value enables the fixed bounded policy (default: 1)
# max_resume_attempts: 1

# Default iterate iteration budget when --max-iterations is omitted
# (1 iteration = code-change task [implement/improve] + review; default: 3)
# iterate_max_iterations: 3

# --- Watch loop ---

# Continuous worker loop defaults (`gza watch`)
# watch:
#   batch: 5
#   poll: 300
#   no_activity_timeout: 60
#   max_idle: null
#   max_iterations: 10

# --- Claude-specific configuration ---
# claude:
#   # Fetch OAuth token from macOS Keychain for Docker (macOS only)
#   fetch_auth_token_from_keychain: false
#   # Arguments passed to Claude Code CLI
#   args:
#     - --allowedTools
#     - Read
#     - Write
#     - Edit
#     - Glob
#     - Grep
#     - Bash
