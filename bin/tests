#!/usr/bin/env bash
set -euo pipefail

CORES=$(getconf _NPROCESSORS_ONLN 2>/dev/null || echo 1)
DEFAULT_WORKERS=$((CORES / 2))
if [[ "$DEFAULT_WORKERS" -lt 1 ]]; then
    DEFAULT_WORKERS=1
fi
PYTEST_XDIST_WORKERS="${PYTEST_XDIST_WORKERS:-$DEFAULT_WORKERS}"
PYTEST_FAULTHANDLER_TIMEOUT="${PYTEST_FAULTHANDLER_TIMEOUT:-2}"
RUN_INTEGRATION=0
QUICK_MODE=0
TARGET_ARGS=()
USE_VENV=0

usage() {
    echo "Usage: $0 [--quick [-- <pytest-target> ...]] [-i|--integration]" >&2
    exit 2
}

while [[ "$#" -gt 0 ]]; do
    case "$1" in
        --quick)
            QUICK_MODE=1
            ;;
        -i|--integration)
            RUN_INTEGRATION=1
            ;;
        --)
            shift
            TARGET_ARGS=("$@")
            break
            ;;
        *)
            usage
            ;;
    esac
    shift
done

if [[ -d ".venv/bin" ]]; then
    export PATH="$(pwd)/.venv/bin:$PATH"
    USE_VENV=1
fi

run_tool() {
    if [[ "$USE_VENV" -eq 1 ]]; then
        "$@"
    else
        uv run "$@"
    fi
}

run_python_module() {
    if [[ "$USE_VENV" -eq 1 ]]; then
        python -m "$@"
    else
        uv run python -m "$@"
    fi
}

run_pytest() {
    if [[ "$USE_VENV" -eq 1 ]]; then
        pytest "$@"
    else
        uv run pytest "$@"
    fi
}

current_tree_fingerprint() {
    if [[ "$USE_VENV" -eq 1 ]]; then
        python - <<'PY' 2>/dev/null
from pathlib import Path

from gza.git import Git
from gza.runner import _compute_tree_fingerprint

print(_compute_tree_fingerprint(Git(Path.cwd())) or "")
PY
    else
        uv run python - <<'PY' 2>/dev/null
from pathlib import Path

from gza.git import Git
from gza.runner import _compute_tree_fingerprint

print(_compute_tree_fingerprint(Git(Path.cwd())) or "")
PY
    fi
}

emit_phase_result() {
    local status="$1"
    local phase_name="$2"
    local duration_seconds="$3"
    local tree_fingerprint

    tree_fingerprint="$(current_tree_fingerprint)"
    if [[ "$tree_fingerprint" =~ ^[0-9a-f]{64}$ ]]; then
        echo "gza-verify phase=${status} name=${phase_name} duration_seconds=${duration_seconds}.0 tree_fingerprint=${tree_fingerprint}"
        return
    fi

    echo "gza-verify phase=${status} name=${phase_name} duration_seconds=${duration_seconds}.0"
}

run_phase() {
    local phase_name="$1"
    shift
    local start_seconds
    local end_seconds
    local duration_seconds
    start_seconds=$(date +%s)
    echo "gza-verify phase=start name=${phase_name}"
    if "$@"; then
        end_seconds=$(date +%s)
        duration_seconds=$((end_seconds - start_seconds))
        emit_phase_result passed "${phase_name}" "${duration_seconds}"
    else
        local status=$?
        end_seconds=$(date +%s)
        duration_seconds=$((end_seconds - start_seconds))
        emit_phase_result failed "${phase_name}" "${duration_seconds}"
        return "$status"
    fi
}

echo "verify: mode=$([[ "$QUICK_MODE" -eq 1 ]] && echo quick || echo full) cores=$CORES xdist_workers=$PYTEST_XDIST_WORKERS faulthandler_timeout=${PYTEST_FAULTHANDLER_TIMEOUT}s use_venv=$USE_VENV"

if [[ "$QUICK_MODE" -eq 1 ]]; then
    if [[ "$RUN_INTEGRATION" -eq 1 ]]; then
        echo "Usage: --integration is not supported with --quick" >&2
        exit 2
    fi

    run_phase ruff run_tool ruff check src/gza/
    run_phase checks run_python_module checks
    if [[ "${#TARGET_ARGS[@]}" -gt 0 ]]; then
        run_phase targeted_pytest run_pytest "${TARGET_ARGS[@]}" -x -o "faulthandler_timeout=${PYTEST_FAULTHANDLER_TIMEOUT}"
    else
        echo "quick verify: no targeted pytest args supplied; skipping pytest phase"
    fi
    exit 0
fi

if [[ "${#TARGET_ARGS[@]}" -gt 0 ]]; then
    usage
fi

run_phase ruff run_tool ruff check src/gza/
run_phase ty run_tool ty check src/gza/
run_phase mypy run_tool mypy src/gza/
run_phase checks run_python_module checks
run_phase unit ./bin/test-latency --summary -- tests/ -n "$PYTEST_XDIST_WORKERS" --dist loadscope -x -o "faulthandler_timeout=${PYTEST_FAULTHANDLER_TIMEOUT}"
run_phase functional run_pytest tests_functional/ -n "$PYTEST_XDIST_WORKERS" --dist loadscope -x -o "faulthandler_timeout=${PYTEST_FAULTHANDLER_TIMEOUT}"

if [[ "$RUN_INTEGRATION" -eq 1 ]]; then
    run_phase integration run_pytest tests_integration -xv
fi
