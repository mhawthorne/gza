#!/usr/bin/env bash
set -euo pipefail

CORES=$(getconf _NPROCESSORS_ONLN 2>/dev/null || echo 1)
CI_PARITY_XDIST_WORKERS=2
DEFAULT_WORKERS=$CI_PARITY_XDIST_WORKERS
PYTEST_XDIST_WORKERS="${PYTEST_XDIST_WORKERS:-$DEFAULT_WORKERS}"
PYTEST_FAULTHANDLER_TIMEOUT="${PYTEST_FAULTHANDLER_TIMEOUT:-60}"
RUN_INTEGRATION=0
QUICK_MODE=0
TARGET_ARGS=()
USE_VENV=0
VERIFY_PHASE_CMD=()

usage() {
    echo "Usage: $0 [--quick [-- <pytest-target> ...]] [-i|--integration]" >&2
    exit 2
}

while [[ "$#" -gt 0 ]]; do
    case "$1" in
        --quick)
            QUICK_MODE=1
            ;;
        -i|--integration)
            RUN_INTEGRATION=1
            ;;
        --)
            shift
            TARGET_ARGS=("$@")
            break
            ;;
        *)
            usage
            ;;
    esac
    shift
done

if [[ -d ".venv/bin" ]]; then
    export PATH="$(pwd)/.venv/bin:$PATH"
    USE_VENV=1
    VERIFY_PHASE_CMD=(python -m gza.tools.verify_phase)
else
    VERIFY_PHASE_CMD=(uv run python -m gza.tools.verify_phase)
fi

run_phase() {
    local phase_name="$1"
    shift
    "${VERIFY_PHASE_CMD[@]}" "${phase_name}" -- "$@"
}

echo "verify: mode=$([[ "$QUICK_MODE" -eq 1 ]] && echo quick || echo full) cores=$CORES xdist_workers=$PYTEST_XDIST_WORKERS faulthandler_timeout=${PYTEST_FAULTHANDLER_TIMEOUT}s use_venv=$USE_VENV"

if [[ "$QUICK_MODE" -eq 1 ]]; then
    if [[ "$RUN_INTEGRATION" -eq 1 ]]; then
        echo "Usage: --integration is not supported with --quick" >&2
        exit 2
    fi

    if [[ "$USE_VENV" -eq 1 ]]; then
        run_phase ruff ruff check src/gza/
        run_phase checks python -m checks
    else
        run_phase ruff uv run ruff check src/gza/
        run_phase checks uv run python -m checks
    fi
    if [[ "${#TARGET_ARGS[@]}" -gt 0 ]]; then
        if [[ "$USE_VENV" -eq 1 ]]; then
            run_phase targeted_pytest pytest "${TARGET_ARGS[@]}" -x -o "faulthandler_timeout=${PYTEST_FAULTHANDLER_TIMEOUT}"
        else
            run_phase targeted_pytest uv run pytest "${TARGET_ARGS[@]}" -x -o "faulthandler_timeout=${PYTEST_FAULTHANDLER_TIMEOUT}"
        fi
    else
        echo "quick verify: no targeted pytest args supplied; skipping pytest phase"
    fi
    exit 0
fi

if [[ "${#TARGET_ARGS[@]}" -gt 0 ]]; then
    usage
fi

if [[ "$USE_VENV" -eq 1 ]]; then
    run_phase ruff ruff check src/gza/
    run_phase ty ty check src/gza/
    run_phase mypy mypy src/gza/
    run_phase checks python -m checks
else
    run_phase ruff uv run ruff check src/gza/
    run_phase ty uv run ty check src/gza/
    run_phase mypy uv run mypy src/gza/
    run_phase checks uv run python -m checks
fi
run_phase unit ./bin/test-unit --summary -- tests/ -n "$PYTEST_XDIST_WORKERS" --dist loadscope --durations=25 -o "faulthandler_timeout=${PYTEST_FAULTHANDLER_TIMEOUT}"
if [[ "$USE_VENV" -eq 1 ]]; then
    run_phase functional ./bin/test-functional -- tests_functional/ -n "$PYTEST_XDIST_WORKERS" --dist loadscope -x --durations=25 -o "faulthandler_timeout=${PYTEST_FAULTHANDLER_TIMEOUT}"
else
    run_phase functional ./bin/test-functional -- tests_functional/ -n "$PYTEST_XDIST_WORKERS" --dist loadscope -x --durations=25 -o "faulthandler_timeout=${PYTEST_FAULTHANDLER_TIMEOUT}"
fi

if [[ "$RUN_INTEGRATION" -eq 1 ]]; then
    if [[ "$USE_VENV" -eq 1 ]]; then
        run_phase integration pytest tests_integration -xv
    else
        run_phase integration uv run pytest tests_integration -xv
    fi
fi
