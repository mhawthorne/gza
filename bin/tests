#!/bin/sh
set -ex

CORES=$(getconf _NPROCESSORS_ONLN 2>/dev/null || echo 1)
DEFAULT_WORKERS=$((CORES / 2))
[ "$DEFAULT_WORKERS" -lt 1 ] && DEFAULT_WORKERS=1
PYTEST_XDIST_WORKERS="${PYTEST_XDIST_WORKERS:-$DEFAULT_WORKERS}"
PYTEST_FAULTHANDLER_TIMEOUT="${PYTEST_FAULTHANDLER_TIMEOUT:-2}"
RUN_INTEGRATION=0

while [ "$#" -gt 0 ]; do
    case "$1" in
        -i|--integration)
            RUN_INTEGRATION=1
            ;;
        *)
            echo "Usage: $0 [-i|--integration]" >&2
            exit 2
            ;;
    esac
    shift
done

uv run ruff check src/gza/
uv run ty check src/gza/
uv run mypy src/gza/
uv run python -m checks
uv run pytest tests/ -n "$PYTEST_XDIST_WORKERS" --dist loadscope -x -o faulthandler_timeout=$PYTEST_FAULTHANDLER_TIMEOUT
uv run pytest tests_functional/ -x -o faulthandler_timeout=$PYTEST_FAULTHANDLER_TIMEOUT

if [ "$RUN_INTEGRATION" -eq 1 ]; then
    uv run pytest tests_integration -xv
fi
